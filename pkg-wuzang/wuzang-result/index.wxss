.page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 88rpx) 24rpx calc(132rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 18% 0%, rgba(190, 236, 219, 0.42), transparent 34%),
    linear-gradient(180deg, #f7fbf8 0%, #f2f8f5 100%);
  color: #101817;
  overflow-x: hidden;
}

text {
  display: block;
}

button::after {
  border: 0;
}

.nav {
  position: relative;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
}

.nav text {
  color: #101817;
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.back {
  position: absolute;
  left: 0;
  top: 3rpx;
  width: 66rpx;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #15221f;
  font-size: 58rpx;
  line-height: 66rpx;
}

.result-hero {
  min-height: 250rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  overflow: hidden;
  border: 1rpx solid rgba(13, 150, 109, 0.18);
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 90% 22%, rgba(21, 184, 135, 0.18), transparent 32%),
    linear-gradient(135deg, #ecfbf5 0%, #ffffff 100%);
  box-shadow: 0 18rpx 38rpx rgba(20, 109, 80, 0.1);
}

.hero-kicker {
  width: fit-content;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #067f5d;
  background: rgba(9, 149, 108, 0.1);
  font-size: 24rpx;
  line-height: 30rpx;
  font-weight: 800;
}

.hero-title {
  margin-top: 18rpx;
  color: #006b50;
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 900;
}

.hero-desc {
  width: 470rpx;
  margin-top: 12rpx;
  color: #40504c;
  font-size: 27rpx;
  line-height: 40rpx;
}

.result-hero image {
  width: 122rpx;
  height: 122rpx;
  flex: 0 0 122rpx;
}

.panel {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(25, 125, 94, 0.1);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 14rpx 34rpx rgba(27, 84, 63, 0.07);
}

.section-title {
  display: flex;
  align-items: center;
}

.section-title view {
  width: 8rpx;
  height: 38rpx;
  margin-right: 14rpx;
  border-radius: 999rpx;
  background: #0a8f68;
}

.section-title text {
  color: #101817;
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.section-sub {
  margin-top: 8rpx;
  color: #66736f;
  font-size: 25rpx;
  line-height: 34rpx;
}

.chart-card {
  position: relative;
  height: 330rpx;
  margin-top: 20rpx;
  padding: 30rpx 18rpx 18rpx;
  border: 1rpx solid #dceee8;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff, #fbfffd);
  overflow: hidden;
}

.grid-line {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  height: 1rpx;
  background: #e6efeb;
}

.line-1 { top: 78rpx; }
.line-2 { top: 150rpx; }
.line-3 { top: 222rpx; }

.bar-list {
  position: relative;
  z-index: 2;
  height: 282rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.bar-item {
  width: 84rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-wrap {
  height: 226rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}

.bar-value {
  margin-bottom: 6rpx;
  color: #66736f;
  font-size: 20rpx;
  line-height: 24rpx;
  font-weight: 800;
}

.bar {
  width: 34rpx;
  min-height: 18rpx;
  border-radius: 12rpx 12rpx 6rpx 6rpx;
  background: #2baee8;
}

.bar.liver { background: linear-gradient(180deg, #ff5661, #d72d3b); }
.bar.kidney { background: linear-gradient(180deg, #34bdeb, #178ec5); }
.bar.heart { background: linear-gradient(180deg, #24aee7, #1387c3); }
.bar.spleen { background: linear-gradient(180deg, #9ed94b, #6cad27); }
.bar.lung,
.bar.stomach { background: linear-gradient(180deg, #8fd7cb, #3fb199); }

.bar-name {
  margin-top: 10rpx;
  color: #283330;
  font-size: 25rpx;
  line-height: 32rpx;
  font-weight: 900;
}

.result-banner {
  padding: 22rpx;
  border-radius: 22rpx;
  background: #e5f7ee;
}

.result-banner text {
  color: #17231f;
  font-size: 29rpx;
  line-height: 42rpx;
  font-weight: 800;
}

.highlight {
  display: inline;
  color: #df6130;
  font-weight: 900;
}

.organ-detail {
  margin-top: 22rpx;
  padding-bottom: 22rpx;
  border-bottom: 1rpx solid #edf3f0;
}

.organ-detail:last-child {
  padding-bottom: 0;
  border-bottom: 0;
}

.organ-head {
  display: flex;
  align-items: center;
}

.organ-head text:first-child {
  color: #101817;
  font-size: 36rpx;
  line-height: 46rpx;
  font-weight: 900;
}

.organ-head text:first-child::after {
  content: "";
  width: 42rpx;
  height: 5rpx;
  display: block;
  margin-top: 4rpx;
  border-radius: 999rpx;
  background: #df6130;
}

.organ-head text:last-child {
  margin-left: 18rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #fff;
  background: #0a8f68;
  font-size: 23rpx;
  line-height: 28rpx;
  font-weight: 800;
}

.organ-text {
  margin-top: 14rpx;
  color: #3f4d49;
  font-size: 28rpx;
  line-height: 43rpx;
}

.symptom-tags,
.common-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.symptom-tags text,
.common-tags text {
  padding: 9rpx 18rpx;
  border-radius: 999rpx;
  color: #0a8f68;
  background: #e8f7f1;
  font-size: 25rpx;
  line-height: 32rpx;
  font-weight: 800;
}

.recipe-card {
  position: relative;
  min-height: 340rpx;
  margin-top: 20rpx;
  overflow: hidden;
  border: 1rpx solid #e8d8c2;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fffaf2, #ffffff);
}

.recipe-card image {
  position: absolute;
  right: -18rpx;
  bottom: -10rpx;
  width: 288rpx;
  height: 210rpx;
  opacity: 0.82;
}

.recipe-copy {
  position: relative;
  z-index: 2;
  padding: 24rpx;
}

.recipe-title {
  color: #7a4417;
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.recipe-row {
  display: flex;
  margin-top: 16rpx;
}

.recipe-label {
  width: 82rpx;
  color: #a56628;
  font-size: 27rpx;
  line-height: 38rpx;
  font-weight: 900;
}

.recipe-text {
  width: 430rpx;
  color: #3f4d49;
  font-size: 27rpx;
  line-height: 38rpx;
}

.notice {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(10, 143, 104, 0.08);
}

.notice text {
  color: #40504c;
  font-size: 25rpx;
  line-height: 38rpx;
}

.bottom-btn {
  position: fixed;
  left: 38rpx;
  right: 38rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 10;
  height: 76rpx;
  min-height: 76rpx;
  padding: 0;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(180deg, #15b887, #07835f);
  font-size: 30rpx;
  line-height: 76rpx;
  font-weight: 900;
  box-shadow: 0 15rpx 28rpx rgba(0, 122, 90, 0.22);
}
