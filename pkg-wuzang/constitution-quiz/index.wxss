.page{min-height:100vh;padding:calc(env(safe-area-inset-top) + 40rpx) 24rpx 64rpx;background:linear-gradient(180deg,#f3fbf7,#f8fbf9);color:#101817}text{display:block}.topbar{text-align:center;font-size:34rpx;line-height:52rpx;font-weight:900}.progress-card,.question-card{margin-top:24rpx;padding:28rpx;border-radius:28rpx;background:#fff;box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.progress-card text{color:#006b50;font-size:30rpx;font-weight:900}.progress-card>view{height:12rpx;margin-top:18rpx;border-radius:999rpx;background:#e3eee9;overflow:hidden}.progress-card>view>view{height:100%;border-radius:999rpx;background:#0a8f68}.question-title{color:#101817;font-size:42rpx;line-height:58rpx;font-weight:900}.question-tip{margin-top:12rpx;color:#68736f;font-size:27rpx}.option-list{margin-top:28rpx;display:grid;gap:16rpx}.option-list view{padding:24rpx 26rpx;border:2rpx solid #e1ebe7;border-radius:22rpx;background:#fafdfe;color:#26312f;font-size:30rpx;font-weight:800}.option-list view.active{border-color:#0a8f68;background:#ecfbf6;color:#006b50}.next-btn{position:fixed;left:48rpx;right:48rpx;bottom:calc(42rpx + env(safe-area-inset-bottom));height:86rpx;border-radius:999rpx;background:#07966f;color:#fff;font-size:32rpx;font-weight:900;box-shadow:0 16rpx 28rpx rgba(0,137,97,.2)}.next-btn::after{border:0}
