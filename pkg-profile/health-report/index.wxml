<view class="page">
  <view class="nav">
    <view class="back" bindtap="onBack">‹</view>
    <text>健康月报</text>
  </view>

  <view class="hero-card">
    <image src="/assets/images/card-report-art.png" mode="aspectFit" />
    <view>
      <text class="kicker">健康趋势</text>
      <text class="hero-title">六月健康概览</text>
      <text class="hero-desc">汇总 BMI、血脂、心率、血氧、血压，帮助您快速了解近期身体趋势。</text>
    </view>
  </view>

  <view class="month-tabs">
    <text wx:for="{{months}}" wx:key="*this" class="{{index === 1 ? 'active' : ''}}">{{item}}</text>
  </view>

  <view class="summary-panel">
    <view class="summary-item">
      <text>5</text>
      <text>监测项目</text>
    </view>
    <view class="summary-item">
      <text>3</text>
      <text>已有记录</text>
    </view>
    <view class="summary-item">
      <text>2</text>
      <text>待补充</text>
    </view>
  </view>

  <view class="report-card" wx:for="{{reports}}" wx:key="title">
    <view class="report-head">
      <image src="{{item.icon}}" mode="aspectFit" />
      <view>
        <text class="report-title">{{item.title}}</text>
        <text class="report-value">{{item.value}}</text>
      </view>
    </view>
    <text class="report-text">{{item.text}}</text>
  </view>
</view>
