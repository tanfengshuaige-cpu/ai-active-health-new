.page{min-height:100vh;padding:calc(env(safe-area-inset-top) + 54rpx) 24rpx calc(168rpx + env(safe-area-inset-bottom));background:linear-gradient(180deg,#f7fbf8,#f2f8f5);color:#101817;overflow-x:hidden}text{display:block}.header{padding:0 8rpx}.page-title{color:#006b58;font-size:64rpx;line-height:78rpx;font-weight:900}.page-desc{margin-top:8rpx;color:#40504c;font-size:29rpx;line-height:40rpx}.summary-card{margin-top:24rpx;padding:26rpx;border:1rpx solid rgba(10,143,104,.16);border-radius:30rpx;background:linear-gradient(135deg,#e9fbf4,#fff);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.summary-card>view:first-child text:first-child{font-size:36rpx;font-weight:900;color:#006b50}.summary-card>view:first-child text:last-child{margin-top:8rpx;font-size:27rpx;color:#52615c}.summary-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16rpx;margin-top:22rpx}.summary-grid view{padding:20rpx 0;border-radius:22rpx;background:rgba(255,255,255,.86);text-align:center}.summary-grid text:first-child{color:#00764f;font-size:46rpx;font-weight:900}.summary-grid text:last-child{margin-top:6rpx;color:#40504c;font-size:25rpx;font-weight:700}.filter-scroll{white-space:nowrap;margin:26rpx -24rpx 0;padding-left:24rpx}.filter-row{display:flex;gap:14rpx;padding-right:24rpx}.filter-row view{padding:14rpx 30rpx;border-radius:999rpx;background:#eef3f1;color:#4e5a56;font-size:28rpx;font-weight:800}.filter-row view.active{background:#0a8f68;color:#fff}.timeline{display:grid;gap:18rpx;margin-top:24rpx}.record-card{min-height:160rpx;display:flex;align-items:center;padding:22rpx;border:1rpx solid #dceee8;border-radius:28rpx;background:#fff;box-shadow:0 10rpx 28rpx rgba(27,84,63,.05)}.record-card image{width:92rpx;height:92rpx;flex:0 0 92rpx;border-radius:24rpx;background:#eefbf6}.record-copy{flex:1;min-width:0;margin-left:22rpx}.record-copy>view{display:flex;align-items:center;gap:12rpx}.record-copy>view text:first-child{font-size:33rpx;font-weight:900;color:#101817}.record-copy>view text:last-child{padding:7rpx 14rpx;border-radius:999rpx;background:#e6f6f0;color:#0a8f68;font-size:23rpx;font-weight:900;white-space:nowrap}.record-copy>text:nth-child(2){margin-top:8rpx;color:#40504c;font-size:28rpx;line-height:38rpx}.record-copy>text:nth-child(3){margin-top:8rpx;color:#8a9490;font-size:24rpx}.arrow{margin-left:12rpx;color:#0a8f68;font-size:50rpx;font-weight:900}.todo-card{margin-top:26rpx;padding:24rpx;border-radius:28rpx;background:#fff;box-shadow:0 12rpx 34rpx rgba(27,84,63,.06)}.section-title{display:flex;align-items:center}.section-title view{width:8rpx;height:38rpx;margin-right:14rpx;border-radius:999rpx;background:#0a8f68}.section-title text{font-size:34rpx;font-weight:900}.todo-row{min-height:126rpx;display:flex;align-items:center;margin-top:18rpx;padding:18rpx;border:1rpx solid #dceee8;border-radius:24rpx;background:#fbfffd}.todo-row image{width:72rpx;height:72rpx}.todo-row view{flex:1;min-width:0;margin-left:18rpx}.todo-row view text:first-child{font-size:30rpx;font-weight:900}.todo-row view text:last-child{margin-top:6rpx;color:#52615c;font-size:25rpx;line-height:34rpx}.todo-row>text{padding:10rpx 18rpx;border:2rpx solid #0a8f68;border-radius:999rpx;color:#0a8f68;font-size:25rpx;font-weight:900;white-space:nowrap}.tabbar{position:fixed;left:0;right:0;bottom:0;z-index:20;height:calc(128rpx + env(safe-area-inset-bottom));display:flex;align-items:flex-start;justify-content:space-around;padding-top:34rpx;padding-bottom:env(safe-area-inset-bottom);border-top:1rpx solid rgba(0,0,0,.06);background:#fff;box-shadow:0 -8rpx 30rpx rgba(0,0,0,.04)}.tab{width:25%;height:92rpx;display:flex;flex-direction:column;align-items:center;gap:6rpx;color:#8a9490;font-size:26rpx}.tab.active{color:#0a8f68;font-weight:900}.tab-icon{width:46rpx;height:46rpx;position:relative;background:transparent;opacity:.72}.tab.home .tab-icon{background:currentColor;clip-path:polygon(50% 0,94% 38%,80% 38%,80% 100%,58% 100%,58% 67%,42% 67%,42% 100%,20% 100%,20% 38%,6% 38%)}.tab.index .tab-icon{border-radius:50%;background:conic-gradient(currentColor 0 25%,transparent 25% 100%);box-shadow:inset 0 0 0 13rpx rgba(138,148,144,.32)}.tab.record .tab-icon{width:40rpx;height:44rpx;border:5rpx solid currentColor;border-radius:8rpx}.tab.record .tab-icon::before,.tab.record .tab-icon::after{content:"";position:absolute;left:8rpx;right:8rpx;height:4rpx;border-radius:999rpx;background:currentColor}.tab.record .tab-icon::before{top:11rpx}.tab.record .tab-icon::after{top:23rpx}.tab.mine .tab-icon::before{content:"";position:absolute;left:13rpx;top:5rpx;width:20rpx;height:20rpx;border-radius:50%;background:currentColor}.tab.mine .tab-icon::after{content:"";position:absolute;left:7rpx;bottom:5rpx;width:32rpx;height:18rpx;border-radius:18rpx 18rpx 8rpx 8rpx;background:currentColor}
