.page{min-height:100vh;padding:calc(env(safe-area-inset-top) + 88rpx) 24rpx 56rpx;background:radial-gradient(circle at 18% 0%,rgba(191,237,220,.45),transparent 34%),linear-gradient(180deg,#f7fbf8 0%,#f2f8f5 100%);color:#101817}text{display:block}.nav{position:relative;height:72rpx;display:flex;align-items:center;justify-content:center;margin-bottom:18rpx}.nav text{font-size:34rpx;font-weight:900}.back{position:absolute;left:0;top:3rpx;width:66rpx;height:66rpx;display:flex;align-items:center;justify-content:center;font-size:58rpx}.video-card{position:relative;height:390rpx;overflow:hidden;border-radius:30rpx;background:#fff8ef;box-shadow:0 18rpx 38rpx rgba(116,78,35,.09)}.video-card image{width:100%;height:100%;opacity:.92}.video-control{position:absolute;left:24rpx;right:24rpx;bottom:22rpx;display:flex;justify-content:space-between}.video-control text{width:150rpx;height:64rpx;line-height:64rpx;border-radius:999rpx;background:rgba(185,107,38,.9);color:#fff;text-align:center;font-size:28rpx;font-weight:900}.panel{margin-top:24rpx;padding:24rpx;border:1rpx solid rgba(25,125,94,.1);border-radius:28rpx;background:rgba(255,255,255,.97);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.section-title{display:flex;align-items:center}.section-title view{width:8rpx;height:38rpx;margin-right:14rpx;border-radius:999rpx;background:#0a8f68}.section-title text{font-size:34rpx;line-height:44rpx;font-weight:900}.body-text{margin-top:16rpx;color:#40504c;font-size:28rpx;line-height:44rpx}
