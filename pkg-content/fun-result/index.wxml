<view class="page">
  <view class="nav">
    <view class="back" bindtap="onBack">‹</view>
    <text>{{title}}</text>
  </view>

  <view class="result-hero">
    <text class="kicker">AI 生成</text>
    <text class="hero-title">{{conclusion}}</text>
    <text class="hero-desc">结果仅供参考，如有不适建议尽快就医。</text>
    <view class="score">4</view>
  </view>

  <view class="panel">
    <view class="section-title"><view></view><text>结果说明</text></view>
    <text class="body-text">{{desc}}</text>
  </view>

  <view class="panel">
    <view class="section-title"><view></view><text>建议</text></view>
    <view class="advice-row" wx:for="{{suggestions}}" wx:key="title">
      <text>{{item.title}}</text>
      <text>{{item.text}}</text>
    </view>
  </view>

  <view class="notice">该内容仅供参考，不构成医疗诊断/治疗建议，如有不适请及时前往正规医疗机构就诊。</view>
  <button class="bottom-btn" bindtap="goList">返回测评列表</button>
</view>
