.page{min-height:100vh;padding:calc(env(safe-area-inset-top) + 88rpx) 24rpx 56rpx;background:radial-gradient(circle at 18% 0%,rgba(191,237,220,.45),transparent 34%),linear-gradient(180deg,#f7fbf8 0%,#f2f8f5 100%);color:#101817;overflow-x:hidden}text{display:block}.nav{position:relative;height:72rpx;display:flex;align-items:center;justify-content:center;margin-bottom:18rpx}.nav text{font-size:34rpx;line-height:44rpx;font-weight:900}.back{position:absolute;left:0;top:3rpx;width:66rpx;height:66rpx;display:flex;align-items:center;justify-content:center;font-size:58rpx}.hero-card{min-height:250rpx;display:flex;align-items:center;padding:30rpx;border:1rpx solid rgba(21,101,216,.16);border-radius:30rpx;background:linear-gradient(135deg,#f5f9ff,#fff 58%,#eef7ff);box-shadow:0 18rpx 38rpx rgba(36,92,142,.08)}.hero-card image{width:190rpx;height:170rpx;margin-right:12rpx}.kicker{width:fit-content;padding:8rpx 18rpx;border-radius:999rpx;color:#1565d8;background:rgba(21,101,216,.1);font-size:24rpx;font-weight:800}.hero-title{margin-top:18rpx;color:#1565d8;font-size:44rpx;line-height:56rpx;font-weight:900}.hero-desc{margin-top:12rpx;color:#40504c;font-size:27rpx;line-height:40rpx}.section-title{display:flex;align-items:center;margin-top:26rpx}.section-title view{width:8rpx;height:38rpx;margin-right:14rpx;border-radius:999rpx;background:#0a8f68}.section-title text{font-size:34rpx;line-height:44rpx;font-weight:900}.test-grid{display:grid;grid-template-columns:1fr 1fr;gap:18rpx;margin-top:18rpx}.test-card{position:relative;min-height:176rpx;padding:22rpx;border:1rpx solid #dceee8;border-radius:24rpx;background:rgba(255,255,255,.97);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07);overflow:hidden}.test-card.orange{border-color:#f1dfca;background:linear-gradient(135deg,#fffaf2,#fff)}.test-card.green{background:linear-gradient(135deg,#f2fbf7,#fff)}.test-title{position:relative;z-index:1;color:#006b50;font-size:31rpx;line-height:40rpx;font-weight:900}.orange .test-title{color:#b9651f}.test-desc{position:relative;z-index:1;width:210rpx;margin-top:10rpx;color:#40504c;font-size:25rpx;line-height:34rpx}.test-card image{position:absolute;right:-10rpx;bottom:-10rpx;width:120rpx;height:110rpx;opacity:.78}
