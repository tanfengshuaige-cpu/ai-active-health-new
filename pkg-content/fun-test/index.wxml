<view class="page">
  <view class="nav">
    <view class="back" bindtap="onBack">‹</view>
    <text>趣味测评</text>
  </view>

  <view class="hero-card">
    <image src="/assets/images/card-test-art.png" mode="aspectFit" />
    <view>
      <text class="kicker">轻量自测</text>
      <text class="hero-title">更了解自己</text>
      <text class="hero-desc">从常见心理、睡眠和体质问题开始，快速获得状态提示。</text>
    </view>
  </view>

  <view class="section-title">
    <view></view>
    <text>问卷列表</text>
  </view>

  <view class="test-grid">
    <view class="test-card {{item.tone}}" wx:for="{{tests}}" wx:key="title" bindtap="onStart" data-key="{{item.key}}">
      <view>
        <text class="test-title">{{item.title}}</text>
        <text class="test-desc">{{item.desc}}</text>
      </view>
      <image src="/assets/images/card-test-art.png" mode="aspectFit" />
    </view>
  </view>
</view>
