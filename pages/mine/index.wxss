.page{min-height:100vh;padding:calc(env(safe-area-inset-top) + 54rpx) 24rpx calc(168rpx + env(safe-area-inset-bottom));background:linear-gradient(180deg,#f7fbf8,#f2f8f5);color:#101817;overflow-x:hidden}text{display:block}.header-card{position:relative;min-height:360rpx;overflow:hidden;border:1rpx solid rgba(10,143,104,.16);border-radius:32rpx;background:#effbf6;box-shadow:0 16rpx 42rpx rgba(27,84,63,.08)}.header-bg{position:absolute;inset:0;width:100%;height:100%}.header-mask{position:absolute;inset:0;background:linear-gradient(90deg,rgba(247,255,252,.96),rgba(247,255,252,.74),rgba(247,255,252,.15))}.profile{position:relative;z-index:2;display:flex;align-items:center;padding:64rpx 34rpx}.avatar{width:126rpx;height:126rpx;display:flex;align-items:center;justify-content:center;margin-right:26rpx;border:8rpx solid rgba(255,255,255,.92);border-radius:50%;background:rgba(255,255,255,.9);box-shadow:0 10rpx 26rpx rgba(27,84,63,.12)}.avatar image{width:78rpx;height:78rpx}.user-name{font-size:42rpx;line-height:54rpx;font-weight:900;color:#071014}.user-desc{margin-top:10rpx;font-size:28rpx;line-height:40rpx;font-weight:800;color:#8a5d22}.section{margin-top:30rpx}.section-title{display:flex;align-items:center}.section-title view{width:8rpx;height:40rpx;margin-right:16rpx;border-radius:999rpx;background:#0a8f68}.section-title text{font-size:40rpx;line-height:52rpx;font-weight:900}.menu-card{margin-top:22rpx;overflow:hidden;border:1rpx solid #ddebe5;border-radius:28rpx;background:#fff;box-shadow:0 12rpx 34rpx rgba(27,84,63,.06)}.menu-row{min-height:120rpx;display:flex;align-items:center;padding:0 24rpx;border-bottom:1rpx solid #edf3f0}.menu-row:last-child{border-bottom:0}.menu-icon-wrap{width:72rpx;height:72rpx;flex:0 0 72rpx;display:flex;align-items:center;justify-content:center;border-radius:20rpx;background:#eefbf6}.menu-icon-wrap image{width:52rpx;height:52rpx}.menu-copy{flex:1;min-width:0;margin-left:20rpx}.menu-copy text:first-child{font-size:32rpx;line-height:40rpx;font-weight:900;color:#101817}.menu-copy text:last-child{margin-top:4rpx;color:#6a7672;font-size:25rpx;line-height:32rpx;white-space:nowrap}.menu-arrow{color:#a7b1ad;font-size:50rpx;line-height:54rpx}.brand-footer{display:flex;justify-content:center;align-items:center;gap:12rpx;margin-top:50rpx;color:#006b58}.brand-footer text:first-child{font-size:38rpx;line-height:44rpx;font-weight:900}.brand-footer text:last-child{color:#172321;font-size:28rpx;line-height:36rpx;font-weight:800}.tabbar{position:fixed;left:0;right:0;bottom:0;z-index:20;height:calc(128rpx + env(safe-area-inset-bottom));display:flex;align-items:flex-start;justify-content:space-around;padding-top:34rpx;padding-bottom:env(safe-area-inset-bottom);border-top:1rpx solid rgba(0,0,0,.06);background:#fff;box-shadow:0 -8rpx 30rpx rgba(0,0,0,.04)}.tab{width:25%;height:92rpx;display:flex;flex-direction:column;align-items:center;gap:6rpx;color:#8a9490;font-size:26rpx}.tab.active{color:#0a8f68;font-weight:900}.tab-icon{width:46rpx;height:46rpx;position:relative;background:transparent;opacity:.72}.tab.home .tab-icon{background:currentColor;clip-path:polygon(50% 0,94% 38%,80% 38%,80% 100%,58% 100%,58% 67%,42% 67%,42% 100%,20% 100%,20% 38%,6% 38%)}.tab.index .tab-icon{border-radius:50%;background:conic-gradient(currentColor 0 25%,transparent 25% 100%);box-shadow:inset 0 0 0 13rpx rgba(138,148,144,.32)}.tab.record .tab-icon{width:40rpx;height:44rpx;border:5rpx solid currentColor;border-radius:8rpx}.tab.record .tab-icon::before,.tab.record .tab-icon::after{content:"";position:absolute;left:8rpx;right:8rpx;height:4rpx;border-radius:999rpx;background:currentColor}.tab.record .tab-icon::before{top:11rpx}.tab.record .tab-icon::after{top:23rpx}.tab.mine .tab-icon::before{content:"";position:absolute;left:13rpx;top:5rpx;width:20rpx;height:20rpx;border-radius:50%;background:currentColor}.tab.mine .tab-icon::after{content:"";position:absolute;left:7rpx;bottom:5rpx;width:32rpx;height:18rpx;border-radius:18rpx 18rpx 8rpx 8rpx;backgro