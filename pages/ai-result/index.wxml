<view class="page">
  <view class="nav">
    <view class="back" bindtap="onBack">‹</view>
    <text>中医问询结果</text>
  </view>

  <view class="summary-card">
    <view class="summary-copy">
      <text class="eyebrow">今日状态评估</text>
      <text class="summary-title">心肝血虚</text>
      <text class="summary-subtitle">兼见肾虚肝郁证</text>
      <text class="summary-desc">根据您的症状分析，AI 测评参考结果如下。</text>
    </view>
    <view class="summary-art">
      <image src="../../assets/images/ai-consult-hero.png" mode="aspectFill" />
    </view>
  </view>

  <view class="panel organ-panel">
    <view class="section-title">
      <view></view>
      <text>五脏状态</text>
    </view>

    <view class="radar-card">
      <view class="radar">
        <view class="ring ring-1"></view>
        <view class="ring ring-2"></view>
        <view class="ring ring-3"></view>
        <view class="axis axis-1"></view>
        <view class="axis axis-2"></view>
        <view class="axis axis-3"></view>
        <view class="axis axis-4"></view>
        <view class="axis axis-5"></view>
        <view class="radar-fill"></view>
        <text class="label heart">心</text>
        <text class="label liver">肝</text>
        <text class="label spleen">脾</text>
        <text class="label lung">肺</text>
        <text class="label kidney">肾</text>
      </view>
      <view class="organ-list">
        <view class="organ-item {{item.key}}" wx:for="{{organs}}" wx:key="name">
          <text class="organ-name">{{item.name}}</text>
          <text class="organ-value">{{item.value}}</text>
        </view>
      </view>
    </view>

    <text class="hint">指示点越接近圆心表明该脏腑越健康，反之表明状态越差。</text>
  </view>

  <view class="panel">
    <view class="section-title">
      <view></view>
      <text>AI 判断</text>
    </view>
    <view class="diagnosis-list">
      <view class="diagnosis-card {{item.type}}" wx:for="{{diagnosis}}" wx:key="title">
        <view class="diagnosis-head">
          <text>{{item.title}}</text>
          <text>{{item.tag}}</text>
        </view>
        <text class="diagnosis-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="section-title">
      <view></view>
      <text>疾病风险</text>
    </view>
    <view class="risk-tabs">
      <text class="active">一般疾病</text>
      <text>重大疾病</text>
    </view>
    <view class="risk-list">
      <view class="risk-row" wx:for="{{risks}}" wx:key="name">
        <view>
          <text class="risk-name">{{item.name}}</text>
          <text class="risk-alias">{{item.alias}}</text>
        </view>
        <text class="risk-rate">{{item.rate}}</text>
      </view>
    </view>
  </view>

  <view class="panel diet-panel">
    <view class="section-title">
      <view></view>
      <text>食养建议</text>
    </view>
    <view class="recipe-card">
      <view class="recipe-head">
        <text>彭龄茶</text>
        <text>清膈宁心 · 益肾平肝</text>
      </view>
      <view class="recipe-row" wx:for="{{recipe}}" wx:key="label">
        <text class="recipe-label">{{item.label}}</text>
        <text class="recipe-text">{{item.text}}</text>
      </view>
    </view>
  </view>

  <view class="notice">
    <text>该内容仅供参考，不构成医疗诊断/治疗建议，如有不适请及时前往正规医疗机构就诊。</text>
  </view>

  <button class="bottom-btn" bindtap="onBack">返回测评列表</button>
</view>
