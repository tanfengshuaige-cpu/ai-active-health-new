.page{min-height:100vh;padding:calc(env(safe-area-inset-top) + 88rpx) 24rpx 56rpx;background:radial-gradient(circle at 18% 0%,rgba(191,237,220,.45),transparent 34%),linear-gradient(180deg,#f7fbf8 0%,#f2f8f5 100%);color:#101817;overflow-x:hidden}text{display:block}.nav{position:relative;height:72rpx;display:flex;align-items:center;justify-content:center;margin-bottom:18rpx}.nav text{font-size:34rpx;line-height:44rpx;font-weight:900}.back{position:absolute;left:0;top:3rpx;width:66rpx;height:66rpx;display:flex;align-items:center;justify-content:center;font-size:58rpx}.hero-card{min-height:250rpx;display:flex;align-items:center;padding:30rpx;border:1rpx solid rgba(13,150,109,.16);border-radius:30rpx;background:linear-gradient(135deg,#ecfbf5,#fff 58%,#eaf4ff);box-shadow:0 18rpx 38rpx rgba(20,109,80,.09)}.hero-card image{width:190rpx;height:170rpx;margin-right:12rpx}.kicker{width:fit-content;padding:8rpx 18rpx;border-radius:999rpx;color:#067f5d;background:rgba(9,149,108,.1);font-size:24rpx;font-weight:800}.hero-title{margin-top:18rpx;color:#006b50;font-size:44rpx;line-height:56rpx;font-weight:900}.hero-desc{margin-top:12rpx;color:#40504c;font-size:27rpx;line-height:40rpx}.month-tabs{display:flex;justify-content:center;gap:18rpx;margin-top:24rpx}.month-tabs text{width:126rpx;height:56rpx;line-height:56rpx;border:1rpx solid #dceee8;border-radius:999rpx;background:#fff;color:#66736f;text-align:center;font-size:27rpx;font-weight:900}.month-tabs .active{color:#fff;background:#0a8f68;border-color:#0a8f68;box-shadow:0 10rpx 22rpx rgba(0,122,90,.16)}.summary-panel{display:grid;grid-template-columns:repeat(3,1fr);gap:14rpx;margin-top:22rpx;padding:20rpx;border:1rpx solid rgba(25,125,94,.1);border-radius:28rpx;background:rgba(255,255,255,.97);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.summary-item{min-height:120rpx;display:flex;flex-direction:column;align-items:center;justify-content:center;border-radius:22rpx;background:#f2fbf7}.summary-item text:first-child{color:#0a8f68;font-size:42rpx;line-height:48rpx;font-weight:900}.summary-item text:last-child{margin-top:8rpx;color:#40504c;font-size:24rpx;font-weight:800}.report-card{margin-top:22rpx;padding:24rpx;border:1rpx solid rgba(25,125,94,.1);border-radius:28rpx;background:rgba(255,255,255,.97);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.report-head{display:flex;align-items:center}.report-head image{width:78rpx;height:78rpx;margin-right:18rpx}.report-title{color:#101817;font-size:34rpx;line-height:44rpx;font-weight:900}.report-value{margin-top:4rpx;color:#0a8f68;font-size:27rpx;line-height:36rpx;font-weight:900}.report-text{margin-top:18rpx;color:#40504c;font-size:28rpx;line-height:44rpx}
