.page{min-height:100vh;padding:calc(env(safe-area-inset-top) + 42rpx) 24rpx 64rpx;background:linear-gradient(180deg,#f3fbf7,#f8fbf9);color:#101817}text{display:block}.result-hero{padding:34rpx;border-radius:30rpx;background:linear-gradient(135deg,#e9fbf4,#fff);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07);border:1rpx solid rgba(10,143,104,.12)}.eyebrow{width:max-content;padding:8rpx 18rpx;border-radius:999rpx;background:#dff8ee;color:#078c68;font-size:24rpx;font-weight:900}.result-title{margin-top:20rpx;color:#006b50;font-size:64rpx;line-height:78rpx;font-weight:900}.result-desc{margin-top:14rpx;color:#40504c;font-size:30rpx;line-height:48rpx}.risk-card,.advice-card{margin-top:22rpx;padding:24rpx;border-radius:26rpx;background:#fff;box-shadow:0 12rpx 28rpx rgba(27,84,63,.06)}.section-title{display:flex;align-items:center}.section-title view{width:8rpx;height:36rpx;margin-right:12rpx;border-radius:999rpx;background:#0a8f68}.section-title text{font-size:34rpx;font-weight:900}.risk-list{margin-top:18rpx;display:grid;gap:12rpx}.risk-list text{padding:18rpx 20rpx;border-radius:18rpx;background:#f3fbf7;color:#40504c;font-size:28rpx}.advice-card text:first-child{color:#006b50;font-size:32rpx;font-weight:900}.advice-card text:last-child{margin-top:12rpx;color:#40504c;font-size:28rpx;line-height:44rpx}.disclaimer{margin-top:22rpx;color:#7a8581;font-size:25rpx;line-height:40rpx}button{margin:28rpx 0 0;height:86rpx;border-radius:999rpx;background:#07966f;color:#fff;font-size:32rpx;font-weight:900;box-shadow:0 16rpx 28rpx rgba(0,137,97,.2)}button::after{border:0}
