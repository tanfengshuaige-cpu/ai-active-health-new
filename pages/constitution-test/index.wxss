.page{min-height:100vh;padding:calc(env(safe-area-inset-top) + 34rpx) 24rpx 64rpx;background:linear-gradient(180deg,#f3fbf7,#f8fbf9);color:#101817}text{display:block}.topbar{height:56rpx;display:flex;align-items:center;justify-content:center;position:relative;font-size:34rpx;font-weight:900}.topbar text:first-child{position:absolute;left:0;font-size:56rpx;line-height:56rpx;color:#1c2a26}.hero-card{margin-top:24rpx;min-height:310rpx;display:flex;align-items:center;padding:30rpx;border:1rpx solid rgba(10,143,104,.14);border-radius:28rpx;background:linear-gradient(135deg,#ecfbf6,#fff);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07);overflow:hidden}.hero-copy{flex:1;position:relative;z-index:2}.eyebrow{width:max-content;padding:8rpx 18rpx;border-radius:999rpx;background:#dff8ee;color:#078c68;font-size:24rpx;font-weight:900}.hero-title{margin-top:20rpx;color:#006b50;font-size:42rpx;line-height:54rpx;font-weight:900}.hero-desc{margin-top:14rpx;color:#40504c;font-size:28rpx;line-height:42rpx}.hero-card button{margin:24rpx 0 0;width:240rpx;height:72rpx;border-radius:999rpx;background:#07966f;color:#fff;font-size:28rpx;font-weight:900;box-shadow:0 12rpx 22rpx rgba(0,137,97,.2)}.hero-card button::after{border:0}.hero-card image{width:220rpx;height:220rpx;margin-left:8rpx}.section,.notice-card{margin-top:24rpx;padding:24rpx;border-radius:26rpx;background:#fff;box-shadow:0 12rpx 28rpx rgba(27,84,63,.06)}.section-title{display:flex;align-items:center}.section-title view{width:8rpx;height:36rpx;margin-right:12rpx;border-radius:999rpx;background:#0a8f68}.section-title text{font-size:34rpx;font-weight:900}.body-text{margin-top:18rpx;color:#40504c;font-size:29rpx;line-height:46rpx}.notice-row{display:flex;gap:18rpx;padding:20rpx 0;border-bottom:1rpx solid #edf2ef}.notice-row:last-child{border-bottom:0}.notice-row text:first-child{width:150rpx;color:#006b50;font-size:28rpx;font-weight:900}.notice-row text:last-child{flex:1;color:#40504c;font-size:28rpx;line-height:40rpx}.tag-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14rpx;margin-top:20rpx}.tag-grid text{text-align:center;padding:18rpx 0;border-radius:18rpx;background:#ecfbf6;color:#087a5b;font-size:28rpx;font-weight:800}
