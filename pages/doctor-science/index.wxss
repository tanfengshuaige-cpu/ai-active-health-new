.page{min-height:100vh;padding:calc(env(safe-area-inset-top) + 88rpx) 24rpx 56rpx;background:radial-gradient(circle at 20% 0%,rgba(191,237,220,.45),transparent 34%),linear-gradient(180deg,#f7fbf8 0%,#f2f8f5 100%);color:#101817;overflow-x:hidden}text{display:block}.nav{position:relative;height:72rpx;display:flex;align-items:center;justify-content:center;margin-bottom:18rpx}.nav text{font-size:34rpx;line-height:44rpx;font-weight:900}.back{position:absolute;left:0;top:3rpx;width:66rpx;height:66rpx;display:flex;align-items:center;justify-content:center;font-size:58rpx}.scroll-card,.doctor-card{padding:28rpx;border:1rpx solid rgba(25,125,94,.1);border-radius:28rpx;background:rgba(255,255,255,.97);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.page-title{position:relative;padding-left:24rpx;color:#101817;font-size:34rpx;line-height:44rpx;font-weight:900}.page-title::before{content:"";position:absolute;left:0;top:3rpx;width:8rpx;height:38rpx;border-radius:999rpx;background:#0a8f68}.week-grid{display:grid;grid-template-columns:1fr 1fr;gap:16rpx;margin-top:24rpx}.week-card{position:relative;min-height:158rpx;padding:18rpx;border:1rpx solid #dceee8;border-radius:22rpx;background:linear-gradient(135deg,#ffffff,#f2fbf7);overflow:hidden}.week-card:nth-child(2n){background:linear-gradient(135deg,#fffaf2,#ffffff);border-color:#f0dfc7}.day{width:76rpx;height:36rpx;line-height:36rpx;border-radius:999rpx;background:#eaf8f2;color:#07835f;text-align:center;font-size:23rpx;font-weight:900}.lesson{position:relative;z-index:1;width:205rpx;margin-top:12rpx;color:#27312e;font-size:25rpx;line-height:36rpx;font-weight:800}.week-card image{position:absolute;right:8rpx;bottom:8rpx;width:90rpx;height:90rpx;opacity:.82}.doctor-card{margin-top:24rpx}.doctor-title{position:relative;padding-left:24rpx;color:#7a4417;font-size:32rpx;line-height:44rpx;font-weight:900}.doctor-title::before{content:"";position:absolute;left:0;top:3rpx;width:8rpx;height:38rpx;border-radius:999rpx;background:#c9823d}.doctor-intro{position:relative;min-height:222rpx;margin-top:20rpx;padding:22rpx;border:1rpx solid #e8d8c2;border-radius:24rpx;background:linear-gradient(135deg,#fffaf2,#ffffff);overflow:hidden}.doctor-intro text{position:relative;z-index:1;width:410rpx;color:#40504c;font-size:26rpx;line-height:40rpx}.doctor-intro image{position:absolute;right:-18rpx;bottom:-18rpx;width:224rpx;height:206rpx;opacity:.9}.list-title{margin-top:24rpx;color:#101817;font-size:29rpx;font-weight:900}.video-row{display:flex;align-items:center;min-height:64rpx;margin-top:12rpx;padding:0 18rpx;border:1rpx solid #dceee8;border-radius:18rpx;background:#fbfffd}.video-row view{width:8rpx;height:34rpx;margin-right:16rpx;border-radius:999rpx;background:#0a8f68}.video-row text{font-size:26rpx;color:#27312e;line-height:36rpx}
