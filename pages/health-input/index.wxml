<view class="page">
  <view class="nav">
    <view class="back" bindtap="onBack">‹</view>
    <text>健康数据录入</text>
  </view>

  <view class="hero-card">
    <view class="hero-copy">
      <text class="hero-kicker">健康管理</text>
      <text class="hero-title">把今日状态记下来</text>
      <text class="hero-desc">补充心率、血压、血糖与生活习惯，生成更贴近个人的健康建议。</text>
    </view>
    <image class="hero-art" src="../../assets/images/chart-health.png" mode="aspectFit" />
  </view>

  <scroll-view class="metric-tabs" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="tab-list">
      <text class="{{index === 0 ? 'active' : ''}}" wx:for="{{metricTabs}}" wx:key="*this">{{item}}</text>
    </view>
  </scroll-view>

  <view class="panel">
    <view class="section-title"><view></view><text>数据采集（选填）</text></view>
    <view class="form-list">
      <view class="field-row" wx:for="{{fields}}" wx:key="label">
        <text>{{item.label}}</text>
        <view class="input-box">{{item.placeholder}}</view>
      </view>
    </view>
    <button class="inline-btn" bindtap="onSave">保存本组数据</button>
  </view>

  <view class="panel">
    <view class="section-title"><view></view><text>生活习惯</text></view>
    <view class="form-list">
      <view class="field-row" wx:for="{{habits}}" wx:key="label">
        <text>{{item.label}}</text>
        <view class="input-box">{{item.placeholder}}</view>
      </view>
    </view>
    <button class="inline-btn ghost" bindtap="onSave">保存生活习惯</button>
  </view>

  <view class="panel">
    <view class="section-title"><view></view><text>数据趋势</text></view>
    <view class="field-row date-row"><text>开始时间</text><view class="input-box">2026-06-16</view></view>
    <view class="field-row date-row"><text>结束时间</text><view class="input-box">2026-06-26</view></view>
    <button class="inline-btn" bindtap="onQuery">查询趋势</button>
  </view>

  <view class="notice">正常心率：60-100 次/分；血氧通常大于 95%。数据仅供健康管理参考。</view>

  <view class="chart-card">
    <view class="chart-grid">
      <view></view><view></view><view></view><view></view>
    </view>
    <view class="safe-line top"></view>
    <view class="safe-line bottom"></view>
    <view class="trend-line"></view>
    <view class="axis-labels">
      <text>0</text><text>2</text><text>4</text><text>6</text><text>8</text><text>10</text>
    </view>
  </view>
</view>
