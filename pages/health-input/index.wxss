.page{min-height:100vh;padding:calc(env(safe-area-inset-top) + 88rpx) 24rpx 56rpx;background:radial-gradient(circle at 18% 0%,rgba(191,237,220,.45),transparent 34%),linear-gradient(180deg,#f7fbf8 0%,#f2f8f5 100%);color:#101817;overflow-x:hidden}text{display:block}button::after{border:0}.nav{position:relative;height:72rpx;display:flex;align-items:center;justify-content:center;margin-bottom:18rpx}.nav text{font-size:34rpx;line-height:44rpx;font-weight:900}.back{position:absolute;left:0;top:3rpx;width:66rpx;height:66rpx;display:flex;align-items:center;justify-content:center;font-size:58rpx}.hero-card{position:relative;min-height:264rpx;overflow:hidden;padding:32rpx 30rpx;border:1rpx solid rgba(13,150,109,.16);border-radius:30rpx;background:linear-gradient(135deg,#ecfbf5 0%,#fff 56%,#eaf4ff 100%);box-shadow:0 18rpx 38rpx rgba(20,109,80,.09)}.hero-card::after{content:"";position:absolute;inset:0;background:linear-gradient(90deg,rgba(246,252,249,.98) 0%,rgba(246,252,249,.84) 52%,rgba(246,252,249,.08) 100%)}.hero-copy{position:relative;z-index:1;width:430rpx}.hero-kicker{width:fit-content;padding:8rpx 18rpx;border-radius:999rpx;color:#067f5d;background:rgba(9,149,108,.1);font-size:24rpx;line-height:30rpx;font-weight:800}.hero-title{margin-top:18rpx;color:#006b50;font-size:44rpx;line-height:56rpx;font-weight:900}.hero-desc{width:400rpx;margin-top:12rpx;color:#40504c;font-size:27rpx;line-height:40rpx}.hero-art{position:absolute;right:-10rpx;bottom:-12rpx;width:300rpx;height:220rpx;opacity:.9}.metric-tabs{white-space:nowrap;margin:24rpx -24rpx 0;padding-left:24rpx}.tab-list{display:flex;gap:14rpx;padding-right:24rpx}.tab-list text{padding:12rpx 26rpx;border:1rpx solid #dceee8;border-radius:999rpx;background:rgba(255,255,255,.96);color:#5f6865;font-size:27rpx;font-weight:800}.tab-list .active{color:#fff;background:#0a8f68;border-color:#0a8f68;box-shadow:0 10rpx 22rpx rgba(0,122,90,.16)}.panel{margin-top:22rpx;padding:24rpx;border:1rpx solid rgba(25,125,94,.1);border-radius:28rpx;background:rgba(255,255,255,.97);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.section-title{display:flex;align-items:center}.section-title view{width:8rpx;height:38rpx;margin-right:14rpx;border-radius:999rpx;background:#0a8f68}.section-title text{font-size:34rpx;line-height:44rpx;font-weight:900}.form-list{margin-top:20rpx;display:grid;gap:16rpx}.field-row{min-height:82rpx;display:grid;grid-template-columns:156rpx 1fr;align-items:center;gap:16rpx;padding:0 18rpx;border:1rpx solid #e4f1ec;border-radius:20rpx;background:linear-gradient(180deg,#fff,#fbfffd)}.field-row>text{font-size:29rpx;font-weight:900;color:#27312e}.input-box{min-height:62rpx;display:flex;align-items:center;padding:0 20rpx;border-radius:16rpx;background:#f4f7f6;color:#9aa3a0;font-size:26rpx}.date-row{margin-top:16rpx}.inline-btn{height:70rpx;line-height:70rpx;margin:22rpx 0 0;padding:0;border-radius:999rpx;background:linear-gradient(180deg,#15b887,#07835f);color:#fff;font-size:29rpx;font-weight:900;box-shadow:0 12rpx 24rpx rgba(0,122,90,.18)}.inline-btn.ghost{color:#07835f;background:#fff;border:2rpx solid #0a8f68;box-shadow:none}.notice{margin-top:20rpx;padding:20rpx 24rpx;border-radius:22rpx;background:rgba(10,143,104,.08);color:#40504c;font-size:26rpx;line-height:38rpx}.chart-card{position:relative;height:360rpx;margin-top:22rpx;padding:28rpx;border:1rpx solid rgba(25,125,94,.1);border-radius:28rpx;background:rgba(255,255,255,.97);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.chart-grid{height:260rpx;display:grid;grid-template-rows:repeat(4,1fr)}.chart-grid view{border-bottom:1rpx dashed #d5d9dd}.safe-line,.trend-line{position:absolute;left:54rpx;right:36rpx;height:3rpx;border-radius:999rpx}.safe-line{background:#f2a0a6}.safe-line.top{top:112rpx}.safe-line.bottom{top:260rpx}.trend-line{top:210rpx;background:#0a8f68;transform:rotate(-3deg);transform-origin:left center}.axis-labels{position:absolute;left:54rpx;right:36rpx;bottom:24rpx;display:flex;justify-content:space-between;color:#6b7280;font-size:24rpx}
