.page{min-height:100vh;padding:calc(env(safe-area-inset-top) + 88rpx) 24rpx 56rpx;background:radial-gradient(circle at 18% 0%,rgba(191,237,220,.45),transparent 34%),linear-gradient(180deg,#f7fbf8 0%,#f2f8f5 100%);color:#101817}text{display:block}button::after{border:0}.nav{position:relative;height:72rpx;display:flex;align-items:center;justify-content:center;margin-bottom:18rpx}.nav text{font-size:34rpx;font-weight:900}.back{position:absolute;left:0;top:3rpx;width:66rpx;height:66rpx;display:flex;align-items:center;justify-content:center;font-size:58rpx}.panel{margin-top:22rpx;padding:24rpx;border:1rpx solid rgba(25,125,94,.1);border-radius:28rpx;background:rgba(255,255,255,.97);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.section-title{display:flex;align-items:center}.section-title view{width:8rpx;height:38rpx;margin-right:14rpx;border-radius:999rpx;background:#0a8f68}.section-title text{font-size:34rpx;line-height:44rpx;font-weight:900}.field-row{min-height:82rpx;display:grid;grid-template-columns:160rpx 1fr;align-items:center;gap:16rpx;margin-top:16rpx;padding:0 18rpx;border:1rpx solid #e4f1ec;border-radius:20rpx;background:#fbfffd}.field-row>text{font-size:29rpx;font-weight:900}.field-row>view{min-height:62rpx;display:flex;align-items:center;padding:0 20rpx;border-radius:16rpx;background:#f4f7f6;color:#9aa3a0;font-size:26rpx}.inline-btn{height:70rpx;line-height:70rpx;margin:22rpx 0 0;padding:0;border-radius:999rpx;background:linear-gradient(180deg,#15b887,#07835f);color:#fff;font-size:29rpx;font-weight:900}.tabs{display:flex;flex-wrap:wrap;gap:14rpx;margin-top:22rpx}.tabs text{padding:12rpx 24rpx;border:1rpx solid #dceee8;border-radius:999rpx;background:#fff;color:#66736f;font-size:26rpx;font-weight:900}.tabs .active{background:#0a8f68;color:#fff}.notice{margin-top:20rpx;padding:20rpx 24rpx;border-radius:22rpx;background:rgba(10,143,104,.08);color:#40504c;font-size:26rpx;line-height:38rpx}.chart-card{position:relative;height:360rpx;margin-top:22rpx;padding:28rpx;border:1rpx solid rgba(25,125,94,.1);border-radius:28rpx;background:#fff;box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.chart-grid{height:280rpx;display:grid;grid-template-rows:repeat(4,1fr)}.chart-grid view{border-bottom:1rpx dashed #d5d9dd}.safe-line,.trend-line{position:absolute;left:54rpx;right:36rpx;height:3rpx;border-radius:999rpx}.safe-line{background:#f2a0a6}.safe-line.top{top:110rpx}.safe-line.bottom{top:250rpx}.trend-line{top:205rpx;background:#0a8f68;transform:rotate(-3deg);transform-origin:left center}
