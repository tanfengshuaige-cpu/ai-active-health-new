.page{min-height:100vh;padding:calc(env(safe-area-inset-top) + 54rpx) 24rpx calc(164rpx + env(safe-area-inset-bottom));background:radial-gradient(circle at 16% 0%,rgba(191,237,220,.45),transparent 34%),linear-gradient(180deg,#f7fbf8,#f2f8f5);color:#101817;overflow-x:hidden}text{display:block}.nav-title{text-align:center;color:#101817;font-size:36rpx;line-height:48rpx;font-weight:900}.intro-card{margin-top:22rpx;padding:30rpx;border:1rpx solid rgba(25,125,94,.12);border-radius:28rpx;background:linear-gradient(135deg,#f0fff9,#fff);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07);text-align:center}.intro-title{color:#006b50;font-size:42rpx;line-height:54rpx;font-weight:900}.intro-en{margin-top:4rpx;color:#6b7672;font-size:20rpx;letter-spacing:1rpx}.intro-desc{margin-top:20rpx;color:#40504c;font-size:28rpx;line-height:46rpx;text-align:left}.system-scroll{white-space:nowrap;margin:24rpx -24rpx 0;padding-left:24rpx}.system-tabs{display:flex;gap:12rpx;padding-right:24rpx}.system-tabs text{padding:12rpx 28rpx;border:2rpx solid rgba(10,143,104,.18);border-radius:999rpx;background:#fff;color:#26312f;font-size:28rpx;font-weight:800}.system-tabs .active{border-color:#0a8f68;background:#0a8f68;color:#fff}.chart-panel{position:relative;height:520rpx;margin-top:22rpx;padding:28rpx 34rpx;border:1rpx solid rgba(25,125,94,.1);border-radius:28rpx;background:#fff;box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.chart-head{display:flex;align-items:center;justify-content:space-between}.chart-head text:first-child{font-size:32rpx;font-weight:900;color:#101817}.chart-head text:last-child{font-size:24rpx;color:#7a8581}.chart-lines{height:360rpx;margin-top:18rpx;display:grid;grid-template-rows:repeat(4,1fr)}.chart-lines view{border-bottom:1rpx solid #e2e8e5}.trend-line{position:absolute;left:92rpx;right:70rpx;top:220rpx;height:6rpx;border-radius:999rpx;background:#70c84b;transform:rotate(-3deg);transform-origin:left center}.dots{position:absolute;left:86rpx;right:64rpx;top:208rpx;display:flex;justify-content:space-between}.dots view{width:18rpx;height:18rpx;border:4rpx solid #70c84b;border-radius:50%;background:#fff}.x-labels{position:absolute;left:58rpx;right:46rpx;bottom:30rpx;display:flex;justify-content:space-between;color:#64716d;font-size:24rpx}.range-card{display:grid;grid-template-columns:repeat(5,1fr);gap:10rpx;margin-top:22rpx;padding:20rpx;border-radius:28rpx;background:#fff;box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.range-item{text-align:center}.range-item view{height:10rpx;border-radius:999rpx}.range-item text:nth-child(2){margin-top:14rpx;color:#40504c;font-size:25rpx}.range-item text:nth-child(3){margin-top:8rpx;color:#40504c;font-size:23rpx}.range-item .active{color:#0a8f68!important;font-weight:900}.status-card,.season-card{margin-top:22rpx;padding:24rpx;border:1rpx solid rgba(25,125,94,.1);border-radius:28rpx;background:#fff;box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.section-title{display:flex;align-items:center}.section-title view{width:8rpx;height:38rpx;margin-right:14rpx;border-radius:999rpx;background:#0a8f68}.section-title text{font-size:34rpx;line-height:44rpx;font-weight:900}.status-text{margin-top:16rpx;color:#40504c;font-size:28rpx;line-height:44rpx}.season-card{display:flex;align-items:center;background:linear-gradient(135deg,#ecfbf5,#fff)}.season-card image{width:190rpx;height:160rpx;margin-right:18rpx}.season-card text:first-child{color:#006b50;font-size:34rpx;font-weight:900}.season-card text:last-child{margin-top:10rpx;color:#40504c;font-size:27rpx;line-height:40rpx}.tabbar{position:fixed;left:0;right:0;bottom:0;z-index:20;height:calc(128rpx + env(safe-area-inset-bottom));display:flex;align-items:flex-start;justify-content:space-around;padding-top:34rpx;padding-bottom:env(safe-area-inset-bottom);border-top:1rpx solid rgba(0,0,0,.06);background:#fff}.tab{width:25%;height:92rpx;display:flex;flex-direction:column;align-items:center;gap:6rpx;color:#8a9490;font-size:26rpx}.tab.active{color:#0a8f68;font-weight:900}.tab-icon{width:46rpx;height:46rpx;background:currentColor;border-radius:50%;opacity:.72}.tab.home .tab-icon{clip-path:polygon(50% 0,94% 38%,80% 38%,80% 100%,58% 100%,58% 67%,42% 67%,42% 100%,20% 100%,20% 38%,6% 38%);border-radius:0}.tab.record .tab-icon{width:40rpx;height:44rpx;border:5rpx solid currentColor;border-radius:8rpx;background:transparent}.tab.mine .tab-icon{border-radius:50%}
