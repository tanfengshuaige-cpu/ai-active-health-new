.page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 88rpx) 24rpx 56rpx;
  background:
    radial-gradient(circle at 18% 0%, rgba(210, 197, 255, 0.32), transparent 34%),
    linear-gradient(180deg, #f9fbfa 0%, #f3f8f6 100%);
  color: #101817;
  overflow-x: hidden;
}

text {
  display: block;
}

button::after {
  border: 0;
}

.nav {
  position: relative;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
}

.nav text {
  color: #101817;
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.back {
  position: absolute;
  left: 0;
  top: 3rpx;
  width: 66rpx;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #15221f;
  font-size: 58rpx;
  line-height: 66rpx;
}

.hero-card {
  position: relative;
  min-height: 292rpx;
  overflow: hidden;
  padding: 34rpx 30rpx;
  border: 1rpx solid rgba(124, 77, 255, 0.16);
  border-radius: 30rpx;
  background: linear-gradient(135deg, #fcfaff 0%, #ffffff 55%, #f2edff 100%);
  box-shadow: 0 18rpx 38rpx rgba(68, 55, 126, 0.09);
}

.hero-card::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(90deg, rgba(253, 251, 255, 0.98) 0%, rgba(253, 251, 255, 0.86) 48%, rgba(253, 251, 255, 0.12) 100%);
}

.hero-copy {
  position: relative;
  z-index: 2;
  width: 426rpx;
}

.hero-kicker {
  width: fit-content;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #6e43df;
  background: rgba(124, 77, 255, 0.1);
  font-size: 24rpx;
  line-height: 30rpx;
  font-weight: 800;
}

.hero-title {
  margin-top: 18rpx;
  color: #5d35c8;
  font-size: 46rpx;
  line-height: 58rpx;
  font-weight: 900;
}

.hero-desc {
  width: 398rpx;
  margin-top: 12rpx;
  color: #40504c;
  font-size: 27rpx;
  line-height: 40rpx;
}

.hero-art {
  position: absolute;
  right: -18rpx;
  bottom: -16rpx;
  z-index: 0;
  width: 320rpx;
  height: 250rpx;
  opacity: 0.94;
}

.panel {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(82, 69, 140, 0.1);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 14rpx 34rpx rgba(46, 42, 87, 0.07);
}

.section-title {
  display: flex;
  align-items: center;
}

.section-title view {
  width: 8rpx;
  height: 38rpx;
  margin-right: 14rpx;
  border-radius: 999rpx;
  background: #7c4dff;
}

.section-title text {
  color: #101817;
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.paper-card {
  position: relative;
  min-height: 360rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  overflow: hidden;
  border: 2rpx dashed rgba(124, 77, 255, 0.28);
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fbf9ff 100%);
}

.paper-card image {
  width: 168rpx;
  height: 168rpx;
  margin-bottom: 18rpx;
}

.paper-card text {
  color: #4b5563;
  font-size: 28rpx;
  line-height: 38rpx;
  font-weight: 800;
}

.paper-lines {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  top: 44rpx;
  display: grid;
  gap: 54rpx;
}

.paper-lines view {
  height: 2rpx;
  background: rgba(124, 77, 255, 0.09);
}

.start-btn {
  width: 336rpx;
  height: 78rpx;
  min-height: 78rpx;
  margin: 24rpx auto 0;
  padding: 0;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(180deg, #8a61ff, #6a3ee8);
  font-size: 30rpx;
  line-height: 78rpx;
  font-weight: 900;
  box-shadow: 0 15rpx 28rpx rgba(105, 62, 232, 0.22);
}

.sample-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 20rpx;
}

.sample-item {
  min-height: 126rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  border: 1rpx solid #e5ddff;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #ffffff, #fcfaff);
  text-align: center;
}

.sample-item text:first-child {
  color: #5d35c8;
  font-size: 30rpx;
  line-height: 38rpx;
  font-weight: 900;
}

.sample-item text:last-child {
  margin-top: 8rpx;
  color: #66736f;
  font-size: 24rpx;
  line-height: 32rpx;
}

.tips {
  display: grid;
  gap: 16rpx;
  margin-top: 20rpx;
}

.tip-row {
  display: flex;
  min-height: 96rpx;
  padding: 18rpx;
  border: 1rpx solid #e6e0ff;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #ffffff, #fcfbff);
}

.tip-index {
  width: 44rpx;
  height: 44rpx;
  flex: 0 0 44rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  color: #fff;
  background: #7c4dff;
  font-size: 26rpx;
  line-height: 44rpx;
  text-align: center;
  font-weight: 900;
}

.tip-title {
  color: #111817;
  font-size: 29rpx;
  line-height: 38rpx;
  font-weight: 900;
}

.tip-desc {
  margin-top: 6rpx;
  color: #66736f;
  font-size: 25rpx;
  line-height: 34rpx;
}
