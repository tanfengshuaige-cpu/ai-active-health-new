.page{min-height:100vh;padding:calc(env(safe-area-inset-top) + 88rpx) 24rpx calc(132rpx + env(safe-area-inset-bottom));background:radial-gradient(circle at 18% 0%,rgba(191,237,220,.45),transparent 34%),linear-gradient(180deg,#f7fbf8 0%,#f2f8f5 100%);color:#101817;overflow-x:hidden}text{display:block}button::after{border:0}.nav{position:relative;height:72rpx;display:flex;align-items:center;justify-content:center;margin-bottom:18rpx}.nav text{font-size:34rpx;line-height:44rpx;font-weight:900}.back{position:absolute;left:0;top:3rpx;width:66rpx;height:66rpx;display:flex;align-items:center;justify-content:center;font-size:58rpx}.progress-card{padding:24rpx;border:1rpx solid rgba(25,125,94,.1);border-radius:26rpx;background:rgba(255,255,255,.97);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.progress-card>text{color:#006b50;font-size:30rpx;font-weight:900}.progress-card>view{height:12rpx;margin-top:18rpx;border-radius:999rpx;background:#e5f1ed;overflow:hidden}.progress-card>view view{width:72%;height:100%;border-radius:999rpx;background:#0a8f68}.question-card{margin-top:22rpx;padding:24rpx;border:1rpx solid rgba(25,125,94,.1);border-radius:28rpx;background:rgba(255,255,255,.97);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.question-title{display:flex;align-items:flex-start;margin-bottom:18rpx}.question-title text:first-child{width:48rpx;height:48rpx;margin-right:16rpx;border-radius:50%;background:#0a8f68;color:#fff;text-align:center;line-height:48rpx;font-size:27rpx;font-weight:900}.question-title text:last-child{flex:1;color:#101817;font-size:31rpx;line-height:44rpx;font-weight:900}.option-row{display:flex;align-items:center;min-height:70rpx;margin-top:12rpx;padding:0 18rpx;border:1rpx solid #e4f1ec;border-radius:18rpx;background:#fbfffd}.option-row view{width:28rpx;height:28rpx;margin-right:14rpx;border:2rpx solid #c8d8d2;border-radius:50%}.option-row text{color:#40504c;font-size:27rpx}.option-row.active{border-color:#0a8f68;background:#eaf8f2}.option-row.active view{border-color:#0a8f68;background:#0a8f68}.bottom-btn{position:fixed;left:38rpx;right:38rpx;bottom:calc(24rpx + env(safe-area-inset-bottom));height:76rpx;line-height:76rpx;padding:0;border-radius:999rpx;background:linear-gradient(180deg,#15b887,#07835f);color:#fff;font-size:30rpx;font-weight:900;box-shadow:0 15rpx 28rpx rgba(0,122,90,.22)}
