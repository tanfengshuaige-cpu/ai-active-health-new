.page{min-height:100vh;padding:calc(env(safe-area-inset-top) + 88rpx) 24rpx calc(132rpx + env(safe-area-inset-bottom));background:radial-gradient(circle at 18% 0%,rgba(191,237,220,.45),transparent 34%),linear-gradient(180deg,#f7fbf8 0%,#f2f8f5 100%);color:#101817;overflow-x:hidden}text{display:block}button::after{border:0}.nav{position:relative;height:72rpx;display:flex;align-items:center;justify-content:center;margin-bottom:18rpx}.nav text{font-size:34rpx;line-height:44rpx;font-weight:900}.back{position:absolute;left:0;top:3rpx;width:66rpx;height:66rpx;display:flex;align-items:center;justify-content:center;font-size:58rpx}.result-hero{position:relative;min-height:260rpx;padding:32rpx 30rpx;border:1rpx solid rgba(13,150,109,.16);border-radius:30rpx;background:linear-gradient(135deg,#ecfbf5 0%,#fff 58%,#eaf4ff 100%);box-shadow:0 18rpx 38rpx rgba(20,109,80,.09);overflow:hidden}.kicker{width:fit-content;padding:8rpx 18rpx;border-radius:999rpx;color:#067f5d;background:rgba(9,149,108,.1);font-size:24rpx;font-weight:800}.hero-title{margin-top:18rpx;color:#006b50;font-size:44rpx;line-height:56rpx;font-weight:900}.hero-desc{width:410rpx;margin-top:12rpx;color:#40504c;font-size:27rpx;line-height:40rpx}.score{position:absolute;right:34rpx;top:60rpx;width:128rpx;height:128rpx;border:10rpx solid rgba(10,143,104,.14);border-radius:50%;background:#fff;color:#0a8f68;text-align:center;line-height:128rpx;font-size:58rpx;font-weight:900}.panel{margin-top:24rpx;padding:24rpx;border:1rpx solid rgba(25,125,94,.1);border-radius:28rpx;background:rgba(255,255,255,.97);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.section-title{display:flex;align-items:center}.section-title view{width:8rpx;height:38rpx;margin-right:14rpx;border-radius:999rpx;background:#0a8f68}.section-title text{font-size:34rpx;line-height:44rpx;font-weight:900}.body-text{margin-top:16rpx;color:#40504c;font-size:28rpx;line-height:44rpx}.advice-row{margin-top:16rpx;padding:20rpx;border:1rpx solid #dceee8;border-radius:20rpx;background:#fbfffd}.advice-row text:first-child{color:#006b50;font-size:29rpx;font-weight:900}.advice-row text:last-child{margin-top:8rpx;color:#40504c;font-size:27rpx;line-height:40rpx}.notice{margin-top:24rpx;padding:22rpx 24rpx;border-radius:22rpx;background:rgba(10,143,104,.08);color:#40504c;font-size:25rpx;line-height:38rpx}.bottom-btn{position:fixed;left:38rpx;right:38rpx;bottom:calc(24rpx + env(safe-area-inset-bottom));height:76rpx;line-height:76rpx;padding:0;border-radius:999rpx;background:linear-gradient(180deg,#15b887,#07835f);color:#fff;font-size:30rpx;font-weight:900;box-shadow:0 15rpx 28rpx rgba(0,122,90,.22)}
