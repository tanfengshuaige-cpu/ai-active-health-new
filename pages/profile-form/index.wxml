<view class="page">
  <view class="nav"><view class="back" bindtap="onBack">‹</view><text>身份信息</text></view>
  <view class="hero-card">
    <view class="hero-copy">
      <text class="hero-kicker">健康档案</text>
      <text class="hero-title">完善基础身份</text>
      <text class="hero-desc">基础信息越完整，AI 测评越准确，后续建议也更贴近个人情况。</text>
    </view>
    <image class="hero-art" src="../../assets/images/data-user.png" mode="aspectFit" />
  </view>

  <view class="panel">
    <view class="section-title"><view></view><text>基本信息</text></view>
    <view class="form-list">
      <view class="field-row" wx:for="{{rows}}" wx:key="label"><text>{{item.label}}</text><view>{{item.value}}</view></view>
      <view class="field-row"><text>性别</text><view class="gender"><text class="active">男</text><text>女</text></view></view>
    </view>
  </view>
  <view class="tip-box">
    <text>说明</text>
    <text>基础信息填报越完善，AI 测评越精确。</text>
  </view>
  <button class="submit-btn" bindtap="onSave">确认提交</button>
  <view class="privacy">查看《隐私服务条款》</view>
</view>
