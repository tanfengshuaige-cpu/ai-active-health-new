.page{min-height:100vh;padding:calc(env(safe-area-inset-top) + 88rpx) 24rpx 56rpx;background:radial-gradient(circle at 18% 0%,rgba(191,237,220,.45),transparent 34%),linear-gradient(180deg,#f7fbf8 0%,#f2f8f5 100%);color:#101817;overflow-x:hidden}text{display:block}button::after{border:0}.nav{position:relative;height:72rpx;display:flex;align-items:center;justify-content:center;margin-bottom:18rpx}.nav text{font-size:34rpx;line-height:44rpx;font-weight:900}.back{position:absolute;left:0;top:3rpx;width:66rpx;height:66rpx;display:flex;align-items:center;justify-content:center;font-size:58rpx}.hero-card{position:relative;min-height:250rpx;overflow:hidden;padding:32rpx 30rpx;border:1rpx solid rgba(13,150,109,.16);border-radius:30rpx;background:linear-gradient(135deg,#ecfbf5 0%,#fff 58%,#eaf4ff 100%);box-shadow:0 18rpx 38rpx rgba(20,109,80,.09)}.hero-card::after{content:"";position:absolute;inset:0;background:linear-gradient(90deg,rgba(246,252,249,.98) 0%,rgba(246,252,249,.84) 54%,rgba(246,252,249,.08) 100%)}.hero-copy{position:relative;z-index:1;width:430rpx}.hero-kicker{width:fit-content;padding:8rpx 18rpx;border-radius:999rpx;color:#067f5d;background:rgba(9,149,108,.1);font-size:24rpx;line-height:30rpx;font-weight:800}.hero-title{margin-top:18rpx;color:#006b50;font-size:44rpx;line-height:56rpx;font-weight:900}.hero-desc{width:390rpx;margin-top:12rpx;color:#40504c;font-size:27rpx;line-height:40rpx}.hero-art{position:absolute;right:28rpx;bottom:26rpx;width:128rpx;height:128rpx;opacity:.92}.panel{margin-top:24rpx;padding:24rpx;border:1rpx solid rgba(25,125,94,.1);border-radius:28rpx;background:rgba(255,255,255,.97);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.section-title{display:flex;align-items:center}.section-title view{width:8rpx;height:38rpx;margin-right:14rpx;border-radius:999rpx;background:#0a8f68}.section-title text{font-size:34rpx;line-height:44rpx;font-weight:900}.form-list{margin-top:20rpx;display:grid;gap:16rpx}.field-row{min-height:82rpx;display:grid;grid-template-columns:142rpx 1fr;align-items:center;gap:16rpx;padding:0 18rpx;border:1rpx solid #e4f1ec;border-radius:20rpx;background:linear-gradient(180deg,#fff,#fbfffd)}.field-row>text{font-size:29rpx;font-weight:900;color:#27312e}.field-row>view{min-height:62rpx;display:flex;align-items:center;padding:0 20rpx;border-radius:16rpx;background:#f4f7f6;color:#27312e;font-size:27rpx}.gender{gap:18rpx;background:transparent!important;padding:0!important}.gender text{width:118rpx;height:56rpx;line-height:56rpx;border:1rpx solid #dceee8;border-radius:999rpx;background:#fff;color:#5f6865;text-align:center;font-size:26rpx;font-weight:900}.gender .active{border-color:#0a8f68;background:#0a8f68;color:#fff}.tip-box{display:flex;align-items:flex-start;gap:16rpx;margin-top:20rpx;padding:20rpx 24rpx;border-radius:22rpx;background:rgba(10,143,104,.08);color:#40504c}.tip-box text:first-child{flex:0 0 auto;color:#07835f;font-size:27rpx;font-weight:900}.tip-box text:last-child{font-size:27rpx;line-height:38rpx}.submit-btn{height:72rpx;line-height:72rpx;margin:24rpx 0 0;border-radius:999rpx;background:linear-gradient(180deg,#15b887,#07835f);color:#fff;font-size:30rpx;font-weight:900;box-shadow:0 12rpx 24rpx rgba(0,122,90,.18)}.privacy{margin-top:28rpx;text-align:center;color:#4b5563;font-size:26rpx;padding-right:18rpx}
