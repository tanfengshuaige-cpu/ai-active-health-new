.page{min-height:100vh;padding:calc(env(safe-area-inset-top) + 88rpx) 24rpx 56rpx;background:radial-gradient(circle at 20% 0%,rgba(191,237,220,.45),transparent 34%),linear-gradient(180deg,#f7fbf8 0%,#f2f8f5 100%);color:#101817;overflow-x:hidden}text{display:block}.nav{position:relative;height:72rpx;display:flex;align-items:center;justify-content:center;margin-bottom:18rpx}.nav text{font-size:34rpx;line-height:44rpx;font-weight:900}.back{position:absolute;left:0;top:3rpx;width:66rpx;height:66rpx;display:flex;align-items:center;justify-content:center;font-size:58rpx}.hero-image{position:relative;height:316rpx;overflow:hidden;border:1rpx solid rgba(13,150,109,.16);border-radius:30rpx;background:linear-gradient(135deg,#ecfbf5 0%,#fff 54%,#fff7ea 100%);box-shadow:0 18rpx 38rpx rgba(20,109,80,.09)}.hero-image::after{content:"";position:absolute;inset:0;background:linear-gradient(90deg,rgba(246,252,249,.98) 0%,rgba(246,252,249,.78) 48%,rgba(246,252,249,.08) 100%)}.hero-image image{position:absolute;right:-24rpx;bottom:-18rpx;width:430rpx;height:250rpx;opacity:.88}.hero-image view{position:absolute;left:30rpx;top:36rpx;z-index:1}.hero-image text:first-child{color:#087450;font-size:44rpx;line-height:56rpx;font-weight:900}.hero-image text:last-child{width:390rpx;margin-top:14rpx;color:#40504c;font-size:27rpx;line-height:40rpx}.scroll-card{position:relative;margin-top:24rpx;padding:28rpx;border:1rpx solid rgba(25,125,94,.1);border-radius:28rpx;background:rgba(255,255,255,.97);box-shadow:0 14rpx 34rpx rgba(27,84,63,.07)}.scroll-card::before{content:"";position:absolute;left:28rpx;top:32rpx;width:8rpx;height:38rpx;border-radius:999rpx;background:#0a8f68}.scroll-title{padding-left:24rpx;color:#101817;font-size:34rpx;line-height:44rpx;font-weight:900}.scroll-desc{margin-top:20rpx;color:#40504c;font-size:28rpx;line-height:44rpx}.video-title{width:fit-content;max-width:100%;height:56rpx;line-height:56rpx;margin:24rpx 0 16rpx;padding:0 22rpx;border-radius:999rpx;background:#eaf8f2;color:#07835f;font-size:27rpx;font-weight:900}.video-box{position:relative;height:252rpx;overflow:hidden;border-radius:22rpx;background:#edf7f2}.video-box image{width:100%;height:100%;opacity:.82}.play,.full{position:absolute;bottom:18rpx;width:128rpx;height:58rpx;line-height:58rpx;border-radius:999rpx;color:#fff;text-align:center;font-size:26rpx;font-weight:900;box-shadow:0 10rpx 20rpx rgba(0,122,90,.18)}.play{left:22rpx;background:linear-gradient(180deg,#15b887,#07835f)}.full{right:22rpx;background:rgba(16,24,23,.58)}
