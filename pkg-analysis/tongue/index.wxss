.page {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 88rpx) 24rpx 56rpx;
  background:
    radial-gradient(circle at 18% 0%, rgba(190, 236, 219, 0.42), transparent 34%),
    linear-gradient(180deg, #f7fbf8 0%, #f2f8f5 100%);
  color: #101817;
  overflow-x: hidden;
}

text {
  display: block;
}

.nav {
  position: relative;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
}

.nav text {
  color: #101817;
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.back {
  position: absolute;
  left: 0;
  top: 3rpx;
  width: 66rpx;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #15221f;
  font-size: 58rpx;
  line-height: 66rpx;
}

.hero-card {
  position: relative;
  min-height: 250rpx;
  overflow: hidden;
  padding: 30rpx;
  border: 1rpx solid rgba(13, 150, 109, 0.18);
  border-radius: 30rpx;
  background: linear-gradient(135deg, #ecfbf5 0%, #ffffff 58%, #eaf4ff 100%);
  box-shadow: 0 18rpx 38rpx rgba(20, 109, 80, 0.1);
}

.hero-card::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(90deg, rgba(240, 252, 247, 0.98) 0%, rgba(240, 252, 247, 0.82) 50%, rgba(240, 252, 247, 0.08) 100%);
}

.hero-copy {
  position: relative;
  z-index: 2;
  width: 430rpx;
}

.hero-kicker {
  width: fit-content;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #1565d8;
  background: rgba(21, 101, 216, 0.1);
  font-size: 24rpx;
  line-height: 30rpx;
  font-weight: 800;
}

.hero-title {
  margin-top: 18rpx;
  color: #1565d8;
  font-size: 44rpx;
  line-height: 56rpx;
  font-weight: 900;
}

.hero-desc {
  width: 400rpx;
  margin-top: 12rpx;
  color: #40504c;
  font-size: 27rpx;
  line-height: 40rpx;
}

.hero-art {
  position: absolute;
  right: -22rpx;
  bottom: -24rpx;
  z-index: 0;
  width: 292rpx;
  height: 242rpx;
  opacity: 0.9;
}

.capture-card,
.panel,
.action-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(25, 125, 94, 0.1);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow: 0 14rpx 34rpx rgba(27, 84, 63, 0.07);
}

.scan-frame {
  position: relative;
  height: 610rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 50% 40%, rgba(255, 255, 255, 0.1), transparent 32%),
    linear-gradient(180deg, #1f2a26, #151c19);
}

.corner {
  position: absolute;
  width: 54rpx;
  height: 54rpx;
  border-color: #22c58f;
  border-style: solid;
}

.lt { left: 18rpx; top: 18rpx; border-width: 6rpx 0 0 6rpx; border-radius: 18rpx 0 0 0; }
.rt { right: 18rpx; top: 18rpx; border-width: 6rpx 6rpx 0 0; border-radius: 0 18rpx 0 0; }
.lb { left: 18rpx; bottom: 18rpx; border-width: 0 0 6rpx 6rpx; border-radius: 0 0 0 18rpx; }
.rb { right: 18rpx; bottom: 18rpx; border-width: 0 6rpx 6rpx 0; border-radius: 0 0 18rpx 0; }

.tongue-outline {
  position: absolute;
  left: 50%;
  top: 48%;
  width: 360rpx;
  height: 430rpx;
  transform: translate(-50%, -50%);
  border: 7rpx solid rgba(255, 255, 255, 0.24);
  border-top-left-radius: 170rpx 120rpx;
  border-top-right-radius: 170rpx 120rpx;
  border-bottom-left-radius: 190rpx 230rpx;
  border-bottom-right-radius: 190rpx 230rpx;
}

.tongue-outline::before,
.tongue-outline::after {
  content: "";
  position: absolute;
  top: 60rpx;
  width: 90rpx;
  height: 90rpx;
  border: 7rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 50%;
}

.tongue-outline::before {
  left: -66rpx;
}

.tongue-outline::after {
  right: -66rpx;
}

.tongue-line {
  position: absolute;
  left: 50%;
  top: 164rpx;
  width: 6rpx;
  height: 190rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.22);
  transform: translateX(-50%);
}

.scan-tip {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 30rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 28rpx;
  line-height: 38rpx;
  text-align: center;
  font-weight: 800;
}

.safe-note {
  margin-top: 20rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(10, 143, 104, 0.08);
}

.safe-note text {
  color: #40504c;
  font-size: 25rpx;
  line-height: 38rpx;
}

.section-title {
  display: flex;
  align-items: center;
}

.section-title view {
  width: 8rpx;
  height: 38rpx;
  margin-right: 14rpx;
  border-radius: 999rpx;
  background: #0a8f68;
}

.section-title text {
  color: #101817;
  font-size: 34rpx;
  line-height: 44rpx;
  font-weight: 900;
}

.tips {
  display: grid;
  gap: 16rpx;
  margin-top: 20rpx;
}

.tip-row {
  display: flex;
  min-height: 96rpx;
  padding: 18rpx;
  border: 1rpx solid #dceee8;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #ffffff, #fbfffd);
}

.tip-index {
  width: 44rpx;
  height: 44rpx;
  flex: 0 0 44rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  color: #fff;
  background: #0a8f68;
  font-size: 26rpx;
  line-height: 44rpx;
  text-align: center;
  font-weight: 900;
}

.tip-title {
  color: #111817;
  font-size: 29rpx;
  line-height: 38rpx;
  font-weight: 900;
}

.tip-desc {
  margin-top: 6rpx;
  color: #66736f;
  font-size: 25rpx;
  line-height: 34rpx;
}

.action-card {
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-btn,
.camera-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #0a8f68;
  font-size: 27rpx;
  line-height: 36rpx;
  font-weight: 900;
}

.tool-btn {
  width: 150rpx;
}

.tool-btn image {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 10rpx;
}

.camera-btn {
  width: 360rpx;
  height: 106rpx;
  justify-content: center;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(180deg, #15b887, #07835f);
  box-shadow: 0 15rpx 28rpx rgba(0, 122, 90, 0.2);
}

.camera-icon {
  font-size: 46rpx;
  line-height: 46rpx;
  color: #fff;
}
